{
  "name": "@conformvault/sdk",
  "version": "2.2.1",
  "description": "Official TypeScript SDK for the ConformVault Developer API",
  "author": "SecuAAS <dev@secuaas.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.4",
    "@types/node": "^22.15.17"
  },
  "keywords": [
    "conformvault",
    "secuaas",
    "file-storage",
    "encryption",
    "api",
    "sdk",
    "signatures",
    "webhooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/secuaas/conformvault-sdk-ts"
  },
  "homepage": "https://github.com/secuaas/conformvault-sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/secuaas/conformvault-sdk-ts/issues"
  }
}
